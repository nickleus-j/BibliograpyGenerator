<Window x:Class="Bibliographía.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bibliographía"
        xmlns:LibModels="clr-namespace:Bibliography.Lib.Models;assembly=Bibliography.Lib"
        mc:Ignorable="d"
        Title="Bibliographía" Height="500" Width="900">
    <Window.Resources>
        <local:DateOnlyToDateTimeConverter x:Key="DateOnlyConverter"/>
    </Window.Resources>
    <Window.DataContext>
        <local:MainWindowViewModel/>
    </Window.DataContext>
    <DockPanel Margin="5">
        <ScrollViewer DockPanel.Dock="Left" FontFamily="Century Gothic">
            <StackPanel>
                <ListBox ItemsSource="{Binding Entries}" MinWidth="50" ScrollViewer.VerticalScrollBarVisibility="Auto" IsSynchronizedWithCurrentItem="True" x:Name="ReferenceList">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <WrapPanel>
                                <Label Content="{Binding Title}" Padding="5"/>
                                <Label Content="{Binding SourceType}" Padding="5"/>
                            </WrapPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <GroupBox Header="Entries">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Add Entry" Command="{Binding AddEntryCommand}" Margin="5"/>
                        <Button Content="Update Entry" Command="{Binding UpdateEntryCommand}" Margin="5"/>
                        <Button Content="Remove Selected" Command="{Binding RemoveSelectedEntryCommand}" Margin="5"/>
                    </StackPanel>
                </GroupBox>
                <local:BibliographyEntryControl DataContext="{Binding ElementName=ReferenceList, Path=SelectedItem}"/>
            </StackPanel>
        </ScrollViewer>
        <StackPanel DockPanel.Dock="Top" Margin="3">
            
            <DockPanel>
                <WrapPanel DockPanel.Dock="Top">
                    <!-- List Section -->
                    <GroupBox Header="Bibliography Entries" Grid.Row="0" Grid.Column="1" Margin="5">
                        <DataGrid ItemsSource="{Binding Entries}" AutoGenerateColumns="False" IsReadOnly="True" FontFamily="Consolas">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="200"/>
                                <DataGridTextColumn Header="Source Type" Binding="{Binding SourceType}" Width="100"/>
                                <DataGridTextColumn Header="Year" Binding="{Binding PublicationDate.Year}" Width="60"/>
                                <DataGridTextColumn Header="Contributors" Binding="{Binding Contributors.Count}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </WrapPanel>
                <WrapPanel DockPanel.Dock="Bottom">
                    <Label Content="Citation Style:" Width="80"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static local:CitationStyleEnumValues.All}}" SelectedItem="{Binding CitationStyle}" Width="150" FontFamily="Segoe UI Semibold"/>
                </WrapPanel>
                
            </DockPanel>
            <StackPanel Orientation="Horizontal" Margin="5" DockPanel.Dock="Left">
                <Button Content="Generate Text" Command="{Binding GenerateTextCommand}" Margin="5" FontSize="16"/>
                <Button Content="Generate BibTeX" Command="{Binding GenerateBibTeXCommand}" Margin="5" FontSize="16"/>
            </StackPanel>
            <TextBox Text="{Binding GeneratedOutput}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" MinHeight="100" FontFamily="Courier New"/>
        </StackPanel>
        <GroupBox Header="Enter BibTex To Parse" Margin="5" DockPanel.Dock="Bottom">
            <StackPanel>
                <TextBox Text="{Binding BibTexForParse}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"  MinHeight="100" FontFamily="Courier New"/>
                <Button Content="Load BibTex" FontSize="14" Command="{Binding ParseBibTeXCommand}"/>
            </StackPanel>
        </GroupBox>
    </DockPanel>
</Window>
