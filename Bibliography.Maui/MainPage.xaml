<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bibliography.Maui.MainPage"
             BackgroundColor="{AppThemeBinding Light=#F5F6F8, Dark=#121212}">

    <Grid RowDefinitions="*">
        
        <CollectionView x:Name="BibliographyGrid"
                        SelectionMode="Single"
                        Margin="16,0">
            
            <CollectionView.Header>
                <VerticalStackLayout Spacing="16" Padding="0,16,0,16">
                    
                    <VerticalStackLayout Spacing="4" Margin="0,0,0,8">
                        <Label Text="Bibliography Generator" 
                               FontSize="24" 
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#FFFFFF}"/>
                        <Label Text="Parse BibTeX or lookup ISBNs to generate your citations."
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#555, Dark=#A0A0A0}"/>
                    </VerticalStackLayout>

                    <FlexLayout Direction="Row" 
                                Wrap="Wrap" 
                                JustifyContent="SpaceBetween"
                                AlignItems="Stretch">

                        <Border StrokeShape="RoundRectangle 12" 
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" 
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                                Padding="16"
                                Margin="0,0,0,16"
                                FlexLayout.Basis="100%"
                                FlexLayout.Grow="1">
                            
                            <VerticalStackLayout Spacing="12">
                                <Label Text="BibTeX Input" FontAttributes="Bold" FontSize="16"/>
                                <Editor x:Name="BibTexInput"
                                        Placeholder="Paste entries here (@article{...})"
                                        HeightRequest="120"
                                        AutoSize="TextChanges"/>
                                <Button x:Name="ParseButton"
                                        Text="Parse BibTeX"
                                        Clicked="OnParseClicked"
                                        StyleClass="PrimaryAction"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border StrokeShape="RoundRectangle 12" 
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" 
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                                Padding="16"
                                Margin="0,0,0,16"
                                FlexLayout.Basis="100%"
                                FlexLayout.Grow="1">
                            
                            <VerticalStackLayout Spacing="12">
                                <Label Text="Quick Add (Google Books)" FontAttributes="Bold" FontSize="16"/>
                                
                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                    <Entry x:Name="isbnBox" 
                                           Grid.Column="0" 
                                           Placeholder="Enter ISBN" 
                                           Keyboard="Numeric"/>
                                    <ImageButton Grid.Column="1" 
                                                 Source="camera_icon.png" 
                                                 ToolTipProperties.Text="Scan Barcode"
                                                 BackgroundColor="{AppThemeBinding Light=#E8F0FE, Dark=#2D3748}"
                                                 CornerRadius="8"
                                                 Padding="10"
                                                 WidthRequest="48"
                                                 HeightRequest="48"/>
                                </Grid>
                                
                                <Button x:Name="LookupBtn" 
                                        Text="Lookup ISBN" 
                                        Clicked="OnLookupClicked"
                                        StyleClass="SecondaryAction"/>

                                <HorizontalStackLayout Spacing="8" Margin="0,8,0,0">
                                    <Entry x:Name="AppNameBox" Placeholder="App Name" WidthRequest="120" FontSize="12"/>
                                    <Entry x:Name="ApiKeyBox" Placeholder="API Key" IsPassword="True" WidthRequest="120" FontSize="12"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </FlexLayout>

                    <Label Text="Bibliography Entries" FontAttributes="Bold" FontSize="18" Margin="0,8,0,0"/>

                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="32" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="📚" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="No entries yet" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Add citations above to get started." FontSize="14" TextColor="Gray" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 8" 
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" 
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                            Padding="16" 
                            Margin="0,0,0,12">
                        <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto">
                            
                            <Label Grid.Row="0" Grid.Column="0" 
                                   Text="{Binding Title}" 
                                   FontAttributes="Bold" 
                                   FontSize="16" 
                                   TextColor="{AppThemeBinding Light=#0066CC, Dark=#66B2FF}"
                                   LineBreakMode="WordWrap"/>
                                   
                            <Label Grid.Row="0" Grid.Column="1" 
                                   Text="{Binding PublicationDate.Year, StringFormat='({0})'}" 
                                   FontAttributes="Bold"/>

                            <CollectionView Grid.Row="1" Grid.ColumnSpan="2" 
                                            ItemsSource="{Binding Contributors}" 
                                            Margin="0,8">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="•" TextColor="{AppThemeBinding Light=#0066CC, Dark=#66B2FF}"/>
                                            <Label Text="{Binding FirstName}"/>
                                            <Label Text="{Binding LastName}" FontAttributes="Bold"/>
                                        </HorizontalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="12">
                                <Label Text="{Binding Publisher, StringFormat='🏢 {0}'}" FontSize="12" TextColor="Gray"/>
                                <Label Text="{Binding SourceType, StringFormat='🏷️ {0}'}" FontSize="12" TextColor="Gray"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <VerticalStackLayout Spacing="16" Padding="0,16,0,32">
                    
                    <Border StrokeShape="RoundRectangle 12" 
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                            Padding="16">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Generate Bibliography" FontAttributes="Bold" FontSize="16"/>
        
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                                <Picker x:Name="CitationStylePicker"
                                        Grid.Column="0"
                                        Title="Select Citation Style"
                                        BackgroundColor="{AppThemeBinding Light=#F5F6F8, Dark=#2D3748}"
                                        TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"/>
            
                                <Button Grid.Column="1" 
                                        x:Name="FormatButton" 
                                        Text="Format" 
                                        Clicked="OnFormatClicked" 
                                        BackgroundColor="#0055AA" 
                                        TextColor="White"
                                        WidthRequest="100"/>
                            </Grid>

                            <Editor x:Name="FormattedOutputEditor" 
                                    Placeholder="Generated citations will appear here..." 
                                    HeightRequest="150" 
                                    IsReadOnly="True"/>
        
                            <Button x:Name="ExportButton" 
                                    Text="Export All" 
                                    Clicked="OnExportClicked" 
                                    BackgroundColor="#51CF66" 
                                    TextColor="White"/>
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*, Auto">
                        <Label x:Name="EntryCountLabel" Text="0 entries loaded" VerticalOptions="Center" TextColor="Gray"/>
                        <Button Grid.Column="1" x:Name="ClearButton" Text="Clear All" Clicked="OnClearClicked" BackgroundColor="#FF6B6B" TextColor="White" Padding="16,0" HeightRequest="36"/>
                    </Grid>

                </VerticalStackLayout>
            </CollectionView.Footer>
        </CollectionView>
    </Grid>
</ContentPage>